{
    "compilerOptions": {
        "target": "es2020",
        "module": "commonjs",
        "esModuleInterop": true,
        "forceConsistentCasingInFileNames": true,
        "strict": true,
        "skipLibCheck": true,
        "resolveJsonModule": true,
        "allowJs": true,
        "checkJs": false,
        "noEmit": true
    },
    "files": ["hardhat.config.js", "scripts/deploy.js"],
    "exclude": ["node_modules", "artifacts", "cache", "test"]
}