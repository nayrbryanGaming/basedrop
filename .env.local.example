# ============================================================
# BaseDrop - Required Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to git.
# ============================================================

# --- Supabase ---
# Get these from: https://supabase.com → Project Settings → API
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxx.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
# SERVICE_ROLE_KEY is used server-side only. Never expose to browser.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# --- WalletConnect ---
# Get a project ID from: https://cloud.walletconnect.com
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your-walletconnect-project-id

# --- Smart Contract (Base Sepolia - already deployed, change if redeployed) ---
NEXT_PUBLIC_ESCROW_ADDRESS=0x59C16998dFc090642EFFdc485c81adAc64d3ef91
